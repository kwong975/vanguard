{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/SafetyNet.hook.ts\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/AutoLint.hook.ts\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MEMORY_DIR=\"${user_config.memoryDir}\" bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/LoadProjects.hook.ts\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MEMORY_DIR=\"${user_config.memoryDir}\" bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/ShowProjects.hook.ts\"",
            "statusMessage": "Loading projects..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/StopGate.hook.ts\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "MEMORY_DIR=\"${user_config.memoryDir}\" bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/CompletionCheck.hook.ts\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/SessionEndReminder.hook.ts\""
          }
        ]
      }
    ]
  }
}
